#include <iostream>
#include <unordered_map>
#include <string>
using namespace std;

int longestEqual01(string s) {
    unordered_map<int, int> mp;

    int sum = 0;
    int maxLen = 0;

    for (int i = 0; i < s.size(); i++) {

        if (s[i] == '0')
            sum += -1;
        else
            sum += 1;

        // From index 0 to i
        if (sum == 0)
            maxLen = i + 1;

        // Sum already seen
        if (mp.find(sum) != mp.end()) {
            maxLen = max(maxLen, i - mp[sum]);
        }
        else {
            mp[sum] = i; // store first occurrence
        }
    }

    return maxLen;
}

int main() {
    string s;
    cin>> s;

    cout << longestEqual01(s);

    return 0;
}
