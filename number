#include <iostream>
#include <string>
using namespace std;

int main() {
    string s;
    cin >> s;
    int flag = 0;

    for (int i = 0; i < s.size(); i++) {
        if (s[i] >= '0' && s[i] <= '9') {
            flag |= (1 << (s[i] - '0'));
        }
    }

    // (1 << 10) - 1 = 1023, binary 1111111111 (all 10 digits present)
    cout << ((flag == (1 << 10) - 1) ? "yes" : "no");
    return 0;
}
