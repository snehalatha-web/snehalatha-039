#include <iostream>
#include <vector>
#include <limits>
void printCombination(const std::vector<int>& combination) {
    for (size_t i = 0; i < combination.size(); ++i) {
        std::cout << combination[i] << (i + 1 < combination.size() ? " " : "");
    }
    std::cout << "\n";
}
void generateCombinations(int n, int k, int start, std::vector<int>& current) {
    if (current.size() == static_cast<size_t>(k)) {
        printCombination(current);
        return;
    }
    for (int i = start; i <= n; ++i) {
        current.push_back(i);
        generateCombinations(n, k, i + 1, current);
        current.pop_back();
    }
}
int main() {
    int n, k;
    std::cout << "Enter total number of elements (n): ";
    if (!(std::cin >> n) || n <= 0) {
        std::cerr << "Invalid input. n must be a positive integer.\n";
        return 1;
    }
    std::cout << "Enter size of each combination (k): ";
    if (!(std::cin >> k) || k <= 0 || k > n) {
        std::cerr << "Invalid input. k must be between 1 and n.\n";
        return 1;
    }
    std::vector<int> current;
    std::cout << "Combinations of size " << k << " from 1 to " << n << ":\n";
    generateCombinations(n, k, 1, current);
    return 0;
}
