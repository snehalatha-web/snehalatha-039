#include <iostream>
#include <string>
using namespace std;

int main() {
    string st;
    cin >> st;
    int L = st.length();

    // Loop through all possible subsets (2^L)
    for (int mask = 1; mask < (1 << L); mask++) {
        string combi = "";
        for (int j = 0; j < L; j++) {
            if (mask & (1 << j)) {
                combi += st[j];
            }
        }
        cout << combi << endl;
    }

    return 0;
}
